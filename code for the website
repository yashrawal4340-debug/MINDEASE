  <!-- ===== JAVASCRIPT ===== -->
  <script>
    /* ======== STATE ======== */
    const state = {
      user: {},
      quizIndex: 0,
      quizAnswers: [],
      breathingTimer: null,
      breathingPhase: null,
      moodLog: [],
      chatHistory: []
    };

    /* ======== NAVIGATION ======== */
    function navigate(page) {
      document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
      const target = document.getElementById('page-' + page);
      if (target) { target.classList.add('active', 'fade-in'); }
      document.querySelectorAll('.nav-links a').forEach(a => {
        a.classList.toggle('active', a.dataset.page === page);
      });
      window.scrollTo(0, 0);
      if (document.getElementById('navLinks').classList.contains('open')) toggleMenu();
    }
    function toggleMenu() {
      document.getElementById('navLinks').classList.toggle('open');
    }

    /* ======== ONBOARDING ======== */
    function submitOnboarding() {
      const age = document.getElementById('age').value;
      const gender = document.getElementById('gender').value;
      const profession = document.getElementById('profession').value;
      if (!age || !gender || !profession) {
        showToast('Please fill in all fields to continue.');
        return;
      }
      state.user = { age, gender, profession };
      showToast('Welcome, ' + profession + '! 🌟 Let\'s begin.');
      setTimeout(() => navigate('quiz'), 600);
    }

    /* ======== QUIZ DATA ======== */
    const quizQuestions = [
      { q: "How often have you felt overwhelmed by your responsibilities?", cat: "stress" },
      { q: "How often have you felt nervous, anxious, or on edge?", cat: "anxiety" },
      { q: "How often have you had difficulty relaxing even when you had free time?", cat: "anxiety" },
      { q: "How often have you felt down, hopeless, or had little interest in things?", cat: "mood" },
      { q: "How often have you had trouble falling or staying asleep?", cat: "sleep" },
      { q: "How often have you felt more tired or fatigued than usual?", cat: "mood" },
      { q: "How often have you felt difficulty concentrating on tasks?", cat: "stress" },
      { q: "How often have you felt irritable or easily frustrated?", cat: "mood" },
      { q: "How often have you felt unmotivated to do things you usually enjoy?", cat: "motivation" },
      { q: "How often have you avoided social situations or withdrawn from people?", cat: "anxiety" },
      { q: "How often have you experienced headaches, stomachaches, or physical tension?", cat: "stress" },
      { q: "How often have you had racing or uncontrollable worrying thoughts?", cat: "anxiety" }
    ];
    const options = [
      { label: "Not at all", score: 0 },
      { label: "Sometimes", score: 1 },
      { label: "Often", score: 2 },
      { label: "Nearly every day", score: 3 }
    ];
    state.quizAnswers = new Array(quizQuestions.length).fill(null);

    function renderQuestion() {
      const i = state.quizIndex;
      const q = quizQuestions[i];
      const total = quizQuestions.length;
      document.getElementById('quiz-q-num').textContent = 'Question ' + (i + 1) + ' of ' + total;
      document.getElementById('quiz-question-text').textContent = q.q;
      document.getElementById('quiz-counter').textContent = (i + 1) + ' / ' + total;
      document.getElementById('quiz-progress').style.width = ((i + 1) / total * 100).toFixed(0) + '%';
      document.getElementById('quiz-prev-btn').style.display = i === 0 ? 'none' : '';
      document.getElementById('quiz-next-btn').textContent = i === total - 1 ? 'Submit ✓' : 'Next →';

      const grid = document.getElementById('quiz-options');
      grid.innerHTML = '';
      options.forEach((opt, idx) => {
        const btn = document.createElement('button');
        btn.className = 'option-btn' + (state.quizAnswers[i] === idx ? ' selected' : '');
        btn.innerHTML = '<span class="option-bullet"></span>' + opt.label;
        btn.onclick = () => {
          document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
          btn.classList.add('selected');
          state.quizAnswers[i] = idx;
        };
        grid.appendChild(btn);
      });
    }

    function quizNext() {
      if (state.quizAnswers[state.quizIndex] === null) {
        showToast('Please select an answer before continuing.');
        return;
      }
      if (state.quizIndex < quizQuestions.length - 1) {
        state.quizIndex++;
        renderQuestion();
      } else {
        showResult();
      }
    }
    function quizPrev() {
      if (state.quizIndex > 0) { state.quizIndex--; renderQuestion(); }
    }

    function showResult() {
      const total = state.quizAnswers.reduce((sum, val) => sum + (val !== null ? options[val].score : 0), 0);
      const max = quizQuestions.length * 3;
      const pct = (total / max) * 100;

      let emoji, title, desc, badgeClass, badgeText, color;
      if (pct < 30) {
        emoji = '😊'; title = 'You seem mentally stable';
        desc = 'Your responses suggest you are managing your mental well-being well. Keep practicing self-care and healthy habits!';
        badgeClass = 'badge-good'; badgeText = 'Score: ' + total + ' / ' + max + ' — Low Concern';
        color = '#276749';
      } else if (pct < 60) {
        emoji = '😐'; title = 'You may be experiencing moderate stress';
        desc = 'You show some signs of stress or emotional fatigue. Consider speaking with a trusted friend, practicing mindfulness, or consulting a counselor.';
        badgeClass = 'badge-moderate'; badgeText = 'Score: ' + total + ' / ' + max + ' — Moderate';
        color = '#8A5E0A';
      } else {
        emoji = '💙'; title = 'You may be experiencing signs of anxiety or low mood';
        desc = 'Your responses suggest you might be going through a difficult time. It\'s important to reach out to a professional. You are not alone, and help is available.';
        badgeClass = 'badge-concern'; badgeText = 'Score: ' + total + ' / ' + max + ' — Higher Concern';
        color = '#C53030';
      }

      document.getElementById('quiz-area').style.display = 'none';
      document.getElementById('quiz-result').style.display = 'block';
      document.getElementById('result-content').innerHTML = `
    <div class="result-emoji">${emoji}</div>
    <div class="result-title" style="color:${color}">${title}</div>
    <div class="result-desc">${desc}</div>
    <div class="result-score-badge ${badgeClass}">${badgeText}</div>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:0.5rem">
      <button class="btn btn-primary btn-sm" onclick="navigate('chat')">💬 Talk to Mira</button>
      <button class="btn btn-accent btn-sm" onclick="navigate('therapists')">👩‍⚕️ Find a Therapist</button>
      <button class="btn btn-outline btn-sm" onclick="retakeQuiz()">🔄 Retake Quiz</button>
    </div>
    <div class="result-disclaimer">
      ⚠️ <strong>Important:</strong> This is <strong>not a medical diagnosis</strong>. This assessment is for informational and self-awareness purposes only. Please consult a qualified mental health professional if you have concerns about your mental health.
    </div>
  `;
    }
    function retakeQuiz() {
      state.quizIndex = 0;
      state.quizAnswers = new Array(quizQuestions.length).fill(null);
      document.getElementById('quiz-area').style.display = 'block';
      document.getElementById('quiz-result').style.display = 'none';
      renderQuestion();
    }

    /* ======== CHATBOT ======== */
    const botResponses = {
      greet: ["Hi there! 🌸 I'm Mira. How are you feeling today?", "Hello! I'm here to listen. What's on your mind?", "Hey! It's good to have you here. How's your day going?"],
      sad: ["I'm really sorry to hear you're feeling this way. 💙 Can you tell me more about what's going on?", "It's okay to feel sad. You don't have to go through this alone. I'm here.", "Thank you for sharing that with me. Your feelings are valid. What do you think is making you feel this way?"],
      anxious: ["Anxiety can feel really overwhelming. 🌬️ Try taking a slow deep breath with me. Breathe in… and out…", "I understand how unsettling anxiety can be. What's been worrying you most lately?", "You're being really brave by talking about this. Let's take it one step at a time."],
      stressed: ["That sounds really stressful. 😔 It's okay to feel overwhelmed sometimes. What's putting the most pressure on you?", "Stress can pile up quickly. Is there anything specific that's been weighing on you?", "I hear you. Remember — it's okay to take a break and breathe."],
      happy: ["That's wonderful to hear! 🌟 What's been making you feel good?", "I love that! Keep holding onto that feeling. 😊", "It's so great that you're feeling well. Celebrating small wins matters!"],
      default: [
        "I understand how you feel. Do you want to talk more about it?",
        "Thank you for sharing that with me. It takes courage. 💙",
        "It's okay to feel this way. You are not alone.",
        "I'm here for you. What would help you most right now?",
        "That makes a lot of sense. Would you like to explore that feeling more?",
        "You're doing the right thing by talking about it. How long have you felt this way?",
        "I appreciate you opening up. Have you spoken to anyone else about this?",
        "Remember — it's okay to not be okay. Taking small steps is still progress. 🌱"
      ]
    };

    function getBot(text) {
      const t = text.toLowerCase();
      if (/\b(hi|hello|hey|hiya|good morning|good evening)\b/.test(t)) return pick(botResponses.greet);
      if (/\b(sad|crying|cry|unhappy|depressed|depression|hopeless|empty)\b/.test(t)) return pick(botResponses.sad);
      if (/\b(anxious|anxiety|panic|nervous|scared|fear|worry|worried)\b/.test(t)) return pick(botResponses.anxious);
      if (/\b(stress|stressed|overwhelm|pressure|burden|exhausted|tired|burnout)\b/.test(t)) return pick(botResponses.stressed);
      if (/\b(happy|great|good|awesome|better|wonderful|fine|well)\b/.test(t)) return pick(botResponses.happy);
      return pick(botResponses.default);
    }
    function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    function addMsg(text, type) {
      const box = document.getElementById('chat-messages');
      const now = new Date();
      const time = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
      const div = document.createElement('div');
      div.className = 'msg ' + type;
      div.innerHTML = '<div class="msg-bubble">' + text + '</div><div class="msg-time">' + time + '</div>';
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }
    function showTyping() {
      const box = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.className = 'msg bot'; div.id = 'typing-indicator';
      div.innerHTML = '<div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }
    function removeTyping() {
      const t = document.getElementById('typing-indicator');
      if (t) t.remove();
    }

    function sendChat() {
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (!text) return;
      addMsg(text, 'user');
      input.value = '';
      showTyping();
      setTimeout(() => {
        removeTyping();
        addMsg(getBot(text), 'bot');
      }, 900 + Math.random() * 600);
    }

    function initChat() {
      const box = document.getElementById('chat-messages');
      box.innerHTML = '';
      setTimeout(() => addMsg("Hi there! 🌸 I'm Mira, your supportive companion. I'm here to listen — no judgment, just care. How are you feeling today?", 'bot'), 400);
    }

    /* ======== THERAPISTS ======== */
    const therapists = [
      { name: "Dr. Priya Sharma", spec: "Anxiety & Depression", exp: "12 years experience", rating: "⭐⭐⭐⭐⭐", color: "#5B8DB8", initials: "PS" },
      { name: "Dr. Rajan Mehta", spec: "Trauma & PTSD", exp: "9 years experience", rating: "⭐⭐⭐⭐⭐", color: "#6DBF8E", initials: "RM" },
      { name: "Dr. Aanya Kapoor", spec: "Stress & Burnout", exp: "7 years experience", rating: "⭐⭐⭐⭐", color: "#F9A8D4", initials: "AK" },
      { name: "Dr. Vikram Iyer", spec: "Relationships & Grief", exp: "15 years experience", rating: "⭐⭐⭐⭐⭐", color: "#F9C784", initials: "VI" },
      { name: "Dr. Sunita Rao", spec: "Child & Adolescent", exp: "11 years experience", rating: "⭐⭐⭐⭐⭐", color: "#A78BFA", initials: "SR" }
    ];
    function renderTherapists() {
      const grid = document.getElementById('therapist-grid');
      grid.innerHTML = therapists.map(t => `
    <div class="therapist-card">
      <div class="therapist-avatar" style="background:${t.color}">${t.initials}</div>
      <div class="therapist-name">${t.name}</div>
      <div class="therapist-spec">${t.spec}</div>
      <div class="therapist-exp">🎓 ${t.exp}</div>
      <div class="therapist-rating">${t.rating}</div>
      <div class="therapist-btns">
        <button class="btn btn-primary btn-sm" onclick="showToast('📅 Booking call with ${t.name}…')">📞 Book Call</button>
        <button class="btn btn-outline btn-sm" onclick="showToast('🎥 Video session with ${t.name} requested!')">🎥 Video Session</button>
      </div>
    </div>
  `).join('');
    }

    /* ======== HELPLINES ======== */
    const helplines = [
      { name: "iCall (TISS)", number: "9152987821", desc: "Professional counseling by trained psychologists" },
      { name: "Vandrevala Foundation", number: "1860-2662-345", desc: "24/7 mental health support line" },
      { name: "Snehi", number: "044-24640050", desc: "Emotional support and crisis intervention" },
      { name: "AASRA", number: "9820466627", desc: "Crisis counseling and suicide prevention" },
      { name: "iHeal", number: "9152987821", desc: "Support for youth and young adults" },
      { name: "NIMHANS", number: "080-46110007", desc: "National Institute of Mental Health helpdesk" }
    ];
    function renderHelplines() {
      document.getElementById('helpline-grid').innerHTML = helplines.map(h => `
    <div class="helpline-card">
      <div class="helpline-name">${h.name}</div>
      <div class="helpline-number">📞 ${h.number}</div>
      <div class="helpline-desc">${h.desc}</div>
    </div>
  `).join('');
    }

    /* ======== MOOD TRACKER ======== */
    const moodEmojis = { happy: '😊', neutral: '😐', sad: '😔' };
    const moodColors = { happy: '#68D391', neutral: '#F9C784', sad: '#FC8181' };
    function trackMood(mood, btn) {
      document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('selected', 'happy', 'neutral', 'sad'));
      btn.classList.add('selected', mood);
      state.moodLog.push({ mood, time: new Date() });
      renderMoodHistory();
      showToast('Mood logged: ' + moodEmojis[mood] + ' ' + mood);
    }
    function renderMoodHistory() {
      if (state.moodLog.length === 0) return;
      document.getElementById('mood-history').style.display = 'block';
      document.getElementById('mood-dots').innerHTML = state.moodLog.slice(-14).map(m =>
        `<div class="mood-dot" style="background:${moodColors[m.mood]}" title="${m.mood}">${moodEmojis[m.mood]}</div>`
      ).join('');
    }

    /* ======== BREATHING ======== */
    const breathingSeq = [
      { phase: 'inhale', label: 'Breathe In…', duration: 4000 },
      { phase: 'hold', label: 'Hold…', duration: 7000 },
      { phase: 'exhale', label: 'Breathe Out…', duration: 8000 }
    ];
    let breathIdx = 0, breathActive = false;
    function startBreathing() {
      if (breathActive) {
        breathActive = false;
        clearTimeout(state.breathingTimer);
        const circle = document.getElementById('breathe-circle');
        circle.className = 'breathing-circle';
        circle.innerHTML = 'Tap to<br>Start';
        document.getElementById('breathe-status').textContent = 'Session ended. Well done! 🌿';
        return;
      }
      breathActive = true; breathIdx = 0;
      runBreath();
    }
    function runBreath() {
      if (!breathActive) return;
      const step = breathingSeq[breathIdx % 3];
      const circle = document.getElementById('breathe-circle');
      circle.className = 'breathing-circle ' + step.phase;
      circle.textContent = step.label;
      document.getElementById('breathe-status').textContent = 'Cycle ' + (Math.floor(breathIdx / 3) + 1) + ' — Tap to stop';
      breathIdx++;
      state.breathingTimer = setTimeout(runBreath, step.duration);
    }

    /* ======== AFFIRMATIONS ======== */
    const affirmations = [
      '"I am enough, and I am worthy of care and kindness."',
      '"Every day I am growing stronger, even on hard days."',
      '"I give myself permission to heal at my own pace."',
      '"My feelings are valid, and I choose to honor them."',
      '"I am not alone — support is always available to me."',
      '"I deserve happiness, peace, and good mental health."',
      '"I choose to be gentle with myself today."',
      '"Small steps forward are still progress worth celebrating."',
      '"I am resilient. I have overcome challenges before."',
      '"Today I will breathe, and that is enough."'
    ];
    let affirmIdx = 0;
    function newAffirmation() {
      affirmIdx = (affirmIdx + 1) % affirmations.length;
      document.getElementById('affirmation-text').textContent = affirmations[affirmIdx];
    }
    function saveGratitude() {
      const val = document.getElementById('gratitude-input').value.trim();
      if (!val) { showToast('Please write something you\'re grateful for.'); return; }
      showToast('🙏 Gratitude saved! Keep nurturing that mindset.');
      document.getElementById('gratitude-input').value = '';
    }

    /* ======== TOAST ======== */
    let toastTimer;
    function showToast(msg) {
      clearTimeout(toastTimer);
      const t = document.getElementById('toast');
      t.textContent = msg; t.style.display = 'block';
      toastTimer = setTimeout(() => { t.style.display = 'none'; }, 3200);
    }

    /* ======== EMERGENCY ======== */
    function callEmergency() {
      showToast('🆘 Dialing 112 — In a real emergency, please call now!');
    }

    /* ======== INIT ======== */
    renderQuestion();
    renderTherapists();
    renderHelplines();
    initChat();
  </script>
</body>

</html>
